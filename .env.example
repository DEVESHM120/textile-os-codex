# Textile OS — Feasibility Platform
# Copy this file to .env and fill in your values.

# Flask server
FLASK_ENV=development
PORT=5005
TEXTILE_RUNTIME_DIR=.runtime

# Auth secrets — change all of these in production
FF_SECRET_KEY=change-me-in-production
FF_ADMIN_PASSWORD=admin1234
FF_DESIGNER_PASSWORD=designer123
FF_FTC_PASSWORD=ftcmember123
FF_AUTH_COOKIE_NAME=textile_os_auth
# Local dev uses Lax + non-secure through the Vite proxy.
# Production cross-site frontend/backend should use None + true.
FF_AUTH_COOKIE_SAMESITE=Lax
FF_AUTH_COOKIE_SECURE=false

# OpenAI (optional — deterministic fallback used if absent)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# CORS — comma-separated list of allowed frontend origins
# Local dev: leave as default. Production: set to your Vercel URL.
CORS_ORIGINS=http://localhost:5173

# NOTE: Do NOT set VITE_API_BASE for local dev.
# The Vite dev-server proxy (/api -> http://localhost:5005) keeps the auth
# cookie on the same origin (localhost:5173). Setting VITE_API_BASE breaks
# httpOnly cookie authentication.
#
# For production (Vercel frontend + Render backend):
# Set VITE_API_BASE=https://your-app.onrender.com in Vercel env vars.
